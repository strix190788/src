<?xml version="1.0"?>
<robot name="simple_robot">
  
  <!-- ============================================ -->
  <!-- BASE LINK — корпус робота                    -->
  <!-- ============================================ -->
  <link name="base_link">
    <!-- Как выглядит (визуализация) -->
    <visual>
      <geometry>
        <!-- Коробка: длина x ширина x высота (метры) -->
        <box size="0.4 0.3 0.1"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 0.8 1"/>
      </material>
    </visual>
    
    <!-- Форма для столкновений (физика) -->
    <collision>
      <geometry>
        <box size="0.4 0.3 0.1"/>
      </geometry>
    </collision>
    
    <!-- Физические свойства -->
    <inertial>
      <mass value="5.0"/>
      <inertia ixx="0.1" ixy="0.0" ixz="0.0" 
               iyy="0.1" iyz="0.0" izz="0.1"/>
    </inertial>
  </link>
  
  <!-- ============================================ -->
  <!-- CAMERA LINK — камера                         -->
  <!-- ============================================ -->
  <link name="camera_link">
    <visual>
      <geometry>
        <box size="0.05 0.1 0.05"/>
      </geometry>
      <material name="red">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>
  </link>
  
  <!-- Сустав: base_link → camera_link -->
  <joint name="base_to_camera" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <!-- Позиция: 20 см вперёд, 7.5 см вверх -->
    <origin xyz="0.2 0 0.075" rpy="0 0 0"/>
  </joint>
  
  <!-- ============================================ -->
  <!-- LIDAR LINK — лидар                           -->
  <!-- ============================================ -->
  <link name="lidar_link">
    <visual>
      <geometry>
        <cylinder length="0.05" radius="0.05"/>
      </geometry>
      <material name="green">
        <color rgba="0 1 0 1"/>
      </material>
    </visual>
  </link>
  
  <!-- Сустав: base_link → lidar_link -->
  <joint name="base_to_lidar" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
  </joint>
  
  <!-- ============================================ -->
  <!-- LEFT WHEEL — левое колесо                    -->
  <!-- ============================================ -->
  <link name="wheel_left_link">
    <visual>
      <geometry>
        <cylinder length="0.05" radius="0.1"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.05" radius="0.1"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" 
               iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>
  
  <!-- Сустав: base_link → left_wheel (вращающийся!) -->
  <joint name="base_to_left_wheel" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_left_link"/>
    <!-- 17.5 см влево, поворот на 90° вокруг X -->
    <origin xyz="0 0.175 0" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  
  <!-- ============================================ -->
  <!-- RIGHT WHEEL — правое колесо                  -->
  <!-- ============================================ -->
  <link name="wheel_right_link">
    <visual>
      <geometry>
        <cylinder length="0.05" radius="0.1"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.05" radius="0.1"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" 
               iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>
  
  <!-- Сустав: base_link → right_wheel -->
  <joint name="base_to_right_wheel" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_right_link"/>
    <origin xyz="0 -0.175 0" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  
  <!-- ============================================ -->
  <!-- IMU LINK — инерциальный сенсор               -->
  <!-- ============================================ -->
  <link name="imu_link">
    <visual>
      <geometry>
        <box size="0.02 0.02 0.01"/>
      </geometry>
      <material name="yellow">
        <color rgba="1 1 0 1"/>
      </material>
    </visual>
  </link>
  
  <!-- Сустав: base_link → imu_link -->
  <joint name="base_to_imu" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0.055" rpy="0 0 0"/>
  </joint>
  
</robot>